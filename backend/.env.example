# ScanIt 环境配置模板
# 复制此文件为 .env 并填入实际值

# ==================== 应用配置 ====================
APP_NAME=ScanIt
DEBUG=true
LOG_LEVEL=INFO

# ==================== 数据库配置 ====================
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/scanit
DATABASE_POOL_SIZE=10

# ==================== Redis 配置 ====================
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ==================== Qdrant 向量数据库 ====================
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION_NAME=scanit_features

# ==================== 搜索引擎 API Keys ====================
# Google Custom Search JSON API
GOOGLE_API_KEY=your_google_api_key_here
GOOGLE_SEARCH_ENGINE_ID=your_search_engine_id_here

# Bing Search API
BING_API_KEY=your_bing_api_key_here

# 百度搜索 API
BAIDU_API_KEY=your_baidu_api_key_here
BAIDU_SECRET_KEY=your_baidu_secret_key_here

# ==================== 检测阈值配置 ====================
# 文本相似度阈值 (0.0 - 1.0)
TEXT_SIMILARITY_THRESHOLD=0.8

# 图片相似度阈值 (0.0 - 1.0)
IMAGE_SIMILARITY_THRESHOLD=0.85

# 视频相似度阈值 (0.0 - 1.0)
VIDEO_SIMILARITY_THRESHOLD=0.8

# ==================== 任务配置 ====================
MAX_SEARCH_RESULTS=50
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT_SECONDS=3600

# ==================== CORS 配置 ====================
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ==================== 告警配置 ====================
# SMTP 邮件配置
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your_email@example.com
SMTP_PASSWORD=your_smtp_password
SMTP_FROM=scanit@example.com

# Webhook 配置 (支持企业微信/钉钉/Slack)
WEBHOOK_URL=https://hooks.slack.com/services/xxx
WEBHOOK_TYPE=slack

# ==================== 安全配置 ====================
# JWT Secret Key (生产环境务必修改)
JWT_SECRET_KEY=your-secret-key-change-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==================== Sentry 监控 ====================
SENTRY_DSN=https://xxx@sentry.io/xxx

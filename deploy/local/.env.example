# ScanIt 本机开发环境配置
# 复制为 .env 并填写实际值

# ============================================
# 数据库
# ============================================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=scanit_dev_password
POSTGRES_DB=scanit

# ============================================
# JWT 认证
# ============================================
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=dev_secret_key_change_in_production_min_32_chars

# ============================================
# 搜索引擎（选择一个）
# ============================================
# Google Custom Search（免费 100 次/天）
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# 博查 AI（¥0.002/次，推荐国内）
BOCHA_API_KEY=

# ============================================
# LLM 配置
# ============================================
# AI 模式: local / budget / enterprise
AI_TIER=local

# Tier 1: 本地 Ollama（免费，需先安装 Ollama）
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=llama3.2

# Tier 2: 云服务（可选填）
DOUYIN_API_KEY=
ZHIPU_API_KEY=
KIMI_API_KEY=

# ============================================
# 其他（可选）
# ============================================
DEBUG=true

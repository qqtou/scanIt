# ScanIt 环境变量配置模板
# 复制此文件为 .env 并填写实际值

# ============================================
# 基础配置
# ============================================

# 应用名称
APP_NAME=ScanIt

# 调试模式（生产环境设为 false）
DEBUG=false

# 跨域允许的源（多个用逗号分隔）
CORS_ORIGINS=http://localhost:3000,http://localhost:5173

# ============================================
# 数据库配置
# ============================================

# PostgreSQL
POSTGRES_PASSWORD=your_secure_password_here
DATABASE_URL=postgresql+asyncpg://postgres:your_secure_password_here@localhost:5432/scanit
DATABASE_POOL_SIZE=10

# Redis
REDIS_URL=redis://localhost:6379/0

# Qdrant（向量数据库，可选）
QDRANT_URL=http://localhost:6333

# ============================================
# Celery 配置
# ============================================

CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# ============================================
# JWT 认证配置
# ============================================

# JWT 密钥（必须修改！至少 32 字符）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=your_random_secret_key_at_least_32_characters_long

# JWT 算法和过期时间
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ============================================
# 搜索引擎配置（分层策略）
# ============================================

# 搜索引擎选择: google / bing / bocha / serpapi / brightdata
SEARCH_PROVIDER=bocha

# Tier 0: 免费测试层
# Google Custom Search（免费 100 次/天）
# 申请地址: https://console.cloud.google.com → Custom Search JSON API
GOOGLE_API_KEY=
GOOGLE_SEARCH_ENGINE_ID=

# Bing Web Search（免费 1000 次/月）
# 申请地址: https://portal.azure.com → Bing Search v7
BING_API_KEY=

# 百度搜索（API 未完整实现）
BAIDU_API_KEY=
BAIDU_SECRET_KEY=

# Tier 1: 低成本层（推荐国内生产）
# 博查 AI（¥0.002/次，数据不出海）
# 申请地址: https://open.bochaai.com（微信扫码登录）
BOCHA_API_KEY=

# Tier 2: 企业级层
# SerpAPI（$50/5000次）
SERPAPI_KEY=

# Bright Data SERP API（按成功付费，99.9% 成功率）
# 申请地址: https://brightdata.com
BRIGHTDATA_API_KEY=
BRIGHTDATA_ZONE=

# 搜索降级策略（逗号分隔）
SEARCH_FALLBACK_ORDER=bocha,google,bing

# 爬虫模式（禁用推荐，启用有反爬风险）
SEARCH_SCRAPE_ENABLED=false

# 搜索限流
SEARCH_RATE_LIMIT=10
SEARCH_TIMEOUT=30

# ============================================
# 检测阈值配置
# ============================================

TEXT_SIMILARITY_THRESHOLD=0.8
IMAGE_SIMILARITY_THRESHOLD=0.85
VIDEO_SIMILARITY_THRESHOLD=0.8

# 任务配置
MAX_SEARCH_RESULTS=50
MAX_CONCURRENT_TASKS=5
TASK_TIMEOUT_SECONDS=3600

# ============================================
# LLM 配置（三层架构）
# ============================================

# AI 模式: local / budget / enterprise
AI_TIER=local

# Tier 1: 本地推理（免费）
# Ollama 服务地址和模型
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2
OLLAMA_EMBED_MODEL=nomic-embed-text

# Tier 2: 低成本云（¥1-10/月）
# 豆包（¥0.001/K tokens）
DOUYIN_API_KEY=

# 智谱 GLM-4（¥0.01/K tokens）
ZHIPU_API_KEY=

# Kimi（¥0.01/K tokens）
KIMI_API_KEY=

# MiniMax
MINIMAX_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=

# Tier 3: 企业级（¥500+/月）
# 阿里云百炼
ALIYUN_API_KEY=

# OpenAI GPT-4o
OPENAI_API_KEY=

# Anthropic Claude
ANTHROPIC_API_KEY=

# ============================================
# 邮件配置（可选）
# ============================================

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@scanit.com
SMTP_TLS=true

# ============================================
# Webhook 配置（可选）
# ============================================

WEBHOOK_TIMEOUT=10
